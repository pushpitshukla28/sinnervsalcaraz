  "records": [
    {
      "who": "sinner",
      "text": "First Italian player in history to reach ATP World No. 1 ranking (June 2024)."
    },
    {
      "who": "sinner",
      "text": "74–7 win-loss record in 2024 — one of the best single-season records in the Open Era."
    },
    {
      "who": "sinner",
      "text": "Won the ATP Finals title in 2024 and 2025, going undefeated in both editions."
    },
    {
      "who": "alcaraz",
      "text": "Youngest player in the Open Era to reach ATP World No. 1 (at age 19 years, 4 months)."
    },
    {
      "who": "alcaraz",
      "text": "Youngest year-end ATP World No. 1 in history (2022)."
    },
    {
      "who": "alcaraz",
      "text": "Youngest man in history to complete the Career Grand Slam (at age 22, with the 2026 Australian Open)."
    },
    {
      "who": "alcaraz",
      "text": "First player born in the 2000s to win a Grand Slam title (2022 US Open)."
    },
    {
      "who": "both",
      "text": "First time since Federer–Nadal–Djokovic that two players aged under 23 have combined for 10+ Grand Slam titles."
    },
    {
      "who": "both",
      "text": "Their 2025 Roland Garros final is one of the longest and highest-quality finals in Grand Slam history."
    }
